# ============================================================
# KlawTax Frontend — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Backend API ──────────────────────────────────────────────
# Base URL of the KlawTax backend (no trailing slash)
# Development: http://localhost:5000
# Production:  https://api.klawtax.online
VITE_API_BASE_URL=http://localhost:5000

# ── Razorpay ────────────────────────────────────────────────
# Public Razorpay key (starts with "rzp_test_" or "rzp_live_")
# Found in: Razorpay Dashboard → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX

# ── WhatsApp ─────────────────────────────────────────────────
# WhatsApp number in international format without "+" (e.g. 917387731313)
VITE_WA_NUMBER=917387731313

# ── Contact Details ──────────────────────────────────────────
VITE_CONTACT_PHONE=917387731313
VITE_CONTACT_EMAIL=info@klawtax.online

# ── UPI ──────────────────────────────────────────────────────
VITE_UPI_ID=7387731313@hdfc

# ── Optional Feature Flags ───────────────────────────────────
# Set to "true" to enable verbose API logging in the console
VITE_API_DEBUG=false
