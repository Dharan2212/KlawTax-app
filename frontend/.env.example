# ══════════════════════════════════════════════════════════════════════════════
# KlawTax Frontend — Production Environment Template
# Version 1.5 | Phase 7.2 Release Hardening
# ══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
#   cp .env.example .env.local        (local dev)
#   cp .env.example .env.production   (production build)
#   Fill in values before running: vite build
#   Never commit .env.local or .env.production to version control.
#
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# ══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND API
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the KlawTax backend API (no trailing slash)
# Development: http://localhost:5000
# Production:  https://api.klawtax.online
VITE_API_BASE_URL=https://api.klawtax.online


# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT — Razorpay (Public Key Only)
# ─────────────────────────────────────────────────────────────────────────────

# Razorpay public key ID (safe to expose to browser)
# Test:       rzp_test_XXXXXXXXXXXXXXXX
# Production: rzp_live_XXXXXXXXXXXXXXXX
# Get from: Razorpay Dashboard → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX


# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP
# ─────────────────────────────────────────────────────────────────────────────

# WhatsApp number in international format without "+" (e.g. 917387731313)
# Used for wa.me/ pre-filled message links
VITE_WA_NUMBER=917387731313


# ─────────────────────────────────────────────────────────────────────────────
# CONTACT DETAILS
# ─────────────────────────────────────────────────────────────────────────────

VITE_CONTACT_PHONE=917387731313
VITE_CONTACT_EMAIL=info@klawtax.online


# ─────────────────────────────────────────────────────────────────────────────
# UPI
# ─────────────────────────────────────────────────────────────────────────────

VITE_UPI_ID=7387731313@hdfc


# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to enable verbose API request logging in the browser console
# Always false in production
VITE_API_DEBUG=false
