{
  "name": "klawtax-backend",
  "version": "1.0.0",
  "description": "KlawTax.online — Backend API Server (v1.5)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/tests/auth.test.ts && tsx src/tests/rbac.test.ts && tsx src/tests/projectLifecycle.test.ts && tsx src/tests/invoicePayment.test.ts && tsx src/tests/leadLifecycle.test.ts && tsx src/tests/servicesCatalog.test.ts && tsx src/tests/webhook.test.ts && tsx src/tests/healthScheduler.test.ts && tsx src/tests/helpers.test.ts && tsx src/tests/notificationSupport.test.ts",
    "test:watch": "tsx --watch src/tests/auth.test.ts",
    "seed": "tsx src/seeds/runSeeds.ts",
    "build:check": "tsc --noEmit && tsc --project tsconfig.json",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "logs": "pm2 logs klawtax-api",
    "reload": "pm2 reload klawtax-api --update-env",
    "seed:prod": "NODE_ENV=production node dist/seeds/runSeeds.js",
    "health": "curl -sf http://localhost:5000/api/v1/health || exit 1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "uuid": "^14.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "UNLICENSED",
  "private": true
}
