# ─────────────────────────────────────────────
# KlawTax Backend — Local Development
# MVP / Current Working Setup
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000

# MongoDB
# Use local MongoDB first OR MongoDB Atlas once created
MONGODB_URI=mongodb://127.0.0.1:27017/klawtax

# JWT
JWT_SECRET=klawtax_super_secure_access_secret_minimum_64_characters_long_key
JWT_REFRESH_SECRET=klawtax_super_secure_refresh_secret_minimum_64_characters_long_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Frontend Origin
CLIENT_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Razorpay
# CURRENTLY NOT CONFIGURED
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# AWS S3
# CURRENTLY NOT CONFIGURED
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# ─────────────────────────────────────────────
# SMTP Email
# CURRENTLY NOT CONFIGURED
# ─────────────────────────────────────────────
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_NAME=KlawTax
EMAIL_FROM_ADDRESS=klawtaxindia@gmail.com

# ─────────────────────────────────────────────
# Redis
# CURRENTLY OPTIONAL
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Public Business Information
# ─────────────────────────────────────────────
PUBLIC_CONTACT_PHONE=8793949471
PUBLIC_RAZORPAY_PHONE=7020656803
PUBLIC_CONTACT_EMAIL=klawtaxindia@gmail.com
PUBLIC_WEBSITE=https://klawtax.online
PUBLIC_GOOGLE_MAP=https://maps.app.goo.gl/R2j9qv5kD2LfSQjP6?g_st=aw