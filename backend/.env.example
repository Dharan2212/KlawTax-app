# ══════════════════════════════════════════════════════════════════════════════
# KlawTax Backend — Production Environment Template
# Version 1.5 | Phase 7.2 Release Hardening
# ══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
#   cp .env.example .env
#   Fill in all required values before starting the server.
#   Never commit .env to version control.
#
# REQUIRED (★) — server will refuse to start without these.
# RECOMMENDED (◈) — features degrade gracefully without these.
# OPTIONAL (○) — sensible defaults apply.
# ══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

# ○ Runtime environment (development | production | test)
NODE_ENV=production

# ○ Port the HTTP server listens on (default: 5000)
PORT=5000


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — MongoDB Atlas
# ─────────────────────────────────────────────────────────────────────────────

# ★ Full MongoDB Atlas connection string including database name
#   Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
#   Get from: Atlas Dashboard → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://klawtax_prod:<PASSWORD>@<CLUSTER>.mongodb.net/klawtax_prod?retryWrites=true&w=majority


# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION — JWT
# ─────────────────────────────────────────────────────────────────────────────

# ★ Access token signing secret — minimum 64 characters, cryptographically random
#   Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ★ Refresh token signing secret — different from JWT_SECRET, minimum 64 characters
#   Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING

# ○ Access token expiry (default: 15m)
JWT_ACCESS_EXPIRES_IN=15m

# ○ Refresh token expiry (default: 30d)
JWT_REFRESH_EXPIRES_IN=30d


# ─────────────────────────────────────────────────────────────────────────────
# CORS — Allowed Frontend Origins
# ─────────────────────────────────────────────────────────────────────────────

# ○ Frontend URL for CORS allowlist (no trailing slash)
#   Production: https://klawtax.online
#   Staging:    https://staging.klawtax.online
CLIENT_URL=https://klawtax.online


# ─────────────────────────────────────────────────────────────────────────────
# CACHE — Redis / Upstash
# ─────────────────────────────────────────────────────────────────────────────

# ◈ Redis connection URL
#   Upstash (recommended for MVP): rediss://:TOKEN@<host>.upstash.io:6379
#   Local Redis: redis://localhost:6379
#   Without Redis: dashboards/notifications degrade to direct DB queries
REDIS_URL=rediss://:REPLACE_WITH_UPSTASH_TOKEN@<HOST>.upstash.io:6379


# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT — Razorpay
# ─────────────────────────────────────────────────────────────────────────────

# ◈ Razorpay API Key ID (starts with rzp_live_ in production)
#   Get from: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX

# ◈ Razorpay API Key Secret (keep secret — never expose to frontend)
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_KEY_SECRET

# ◈ Razorpay Webhook Secret — used for HMAC-SHA256 signature verification
#   Get from: Razorpay Dashboard → Settings → Webhooks → your webhook → secret
#   Webhook URL to configure: https://api.klawtax.online/api/v1/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_RAZORPAY_WEBHOOK_SECRET


# ─────────────────────────────────────────────────────────────────────────────
# FILE STORAGE — AWS S3
# ─────────────────────────────────────────────────────────────────────────────

# ◈ AWS IAM access key ID (use a dedicated IAM user with S3-only permissions)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# ◈ AWS IAM secret access key
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_ACCESS_KEY

# ◈ AWS region where your S3 bucket is located
AWS_REGION=ap-south-1

# ◈ S3 bucket name (must already exist; enable versioning for production)
#   Recommended: klawtax-prod-documents
AWS_S3_BUCKET=klawtax-prod-documents


# ─────────────────────────────────────────────────────────────────────────────
# EMAIL — SMTP (Transactional Mail)
# ─────────────────────────────────────────────────────────────────────────────

# ◈ SMTP host (e.g. smtp.gmail.com | smtp.sendgrid.net | smtp.mailgun.org)
EMAIL_SMTP_HOST=smtp.gmail.com

# ◈ SMTP port (587 for STARTTLS, 465 for SSL, 25 for plain)
EMAIL_SMTP_PORT=587

# ◈ SMTP username (typically your email address)
EMAIL_SMTP_USER=klawtaxindia@gmail.com

# ◈ SMTP password or app-specific password
#   Gmail: use App Password (16-char), not your account password
#   Get from: Google Account → Security → 2-Step Verification → App passwords
EMAIL_SMTP_PASS=REPLACE_WITH_APP_PASSWORD

# ○ Display name for outbound emails
EMAIL_FROM_NAME=KlawTax

# ○ From address for outbound emails
EMAIL_FROM_ADDRESS=klawtaxindia@gmail.com


# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# ○ Log verbosity (error | warn | info | http | debug)
#   Production recommendation: info
#   Debug only when diagnosing issues — generates high log volume
LOG_LEVEL=info


# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC BUSINESS INFORMATION
# (These appear in WhatsApp message templates and public contact info)
# ─────────────────────────────────────────────────────────────────────────────

# ○ Customer-facing contact phone
PUBLIC_CONTACT_PHONE=8793949471

# ○ Razorpay support phone
PUBLIC_RAZORPAY_PHONE=7020656803

# ○ Customer-facing contact email
PUBLIC_CONTACT_EMAIL=klawtaxindia@gmail.com

# ○ Public website URL
PUBLIC_WEBSITE=https://klawtax.online

# ○ Google Maps link
PUBLIC_GOOGLE_MAP=https://maps.app.goo.gl/R2j9qv5kD2LfSQjP6
